Options -Indexes
ServerSignature Off

<IfModule mod_rewrite.c>
RewriteEngine On

# Block hidden and sensitive files.
RewriteRule "(^|/)\." - [F,L]
RewriteRule ^config/ - [F,L]
RewriteRule ^(?:composer\.(?:json|lock)|package(?:-lock)?\.json|yarn\.lock|pnpm-lock\.yaml|\.env)$ - [F,L,NC]

# Allow only contact.php as executable PHP endpoint.
RewriteCond %{REQUEST_URI} !^/contact\.php$ [NC]
RewriteRule \.php$ - [F,L,NC]

# Default document.
RewriteRule ^$ /index.html [L]
</IfModule>

<IfModule mod_headers.c>
Header always set X-Content-Type-Options "nosniff"
Header always set X-Frame-Options "SAMEORIGIN"
Header always set Referrer-Policy "strict-origin-when-cross-origin"
Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
Header always set Content-Security-Policy "base-uri 'self'; form-action 'self'; frame-ancestors 'self'"
</IfModule>